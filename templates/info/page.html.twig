{% extends 'base.html.twig' %}

{% block title %}{{ page.title }} - Sneakers Store{% endblock %}

{% block body %}
<main class="infoPage">
    <section class="infoPanel">
        <a href="{{ path('app_products') }}" class="infoBack">Back to shop</a>
        <p class="infoKicker">{{ page.kicker }}</p>
        <h1>{{ page.title }}</h1>
        <p class="infoBody">{{ page.body }}</p>
        <div class="infoActions">
            <a href="{{ path('app_products') }}#catalog" class="buttonPrimary">Shop products</a>
            <a href="{{ path('app_feedback') }}" class="buttonOutline">Send feedback</a>
        </div>
    </section>
</main>

{% include '_footer.html.twig' %}
{% endblock %}
