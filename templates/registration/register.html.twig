{% extends 'base.html.twig' %}

{% block title %}Register — Sneakers Store{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="register-card">
        <div class="login-header">
            <h1>Create Account</h1>
            <p class="login-subtitle">Join the sneaker community</p>
        </div>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.email) }}
            {{ form_row(registrationForm.plainPassword, {
                label: 'Password'
            }) }}
            {{ form_row(registrationForm.agreeTerms) }}

            <button type="submit" class="buttonPrimary">Register</button>
        {{ form_end(registrationForm) }}

        <div class="login-footer">
            <p>Already have an account? <a href="{{ path('app_login') }}">Sign in</a></p>
        </div>
    </div>
</div>
{% endblock %}
