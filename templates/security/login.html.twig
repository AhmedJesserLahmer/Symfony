{% extends 'base.html.twig' %}

{% block title %}Connexion — Sneakers Store{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h1>Connexion</h1>
                <p class="login-subtitle">Accédez à votre compte</p>
            </div>

            {% if error %}
                <div class="alert alert-danger alert-dismissible" role="alert">
                    <strong>Erreur d'authentification</strong>
                    <p>{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                </div>
            {% endif %}

            {% if app.user %}
                <div class="alert alert-info alert-dismissible" role="alert">
                    <strong>Déjà connecté</strong>
                    <p>Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong></p>
                    <div style="margin-top: 10px;">
                        <a href="{{ logout_path() }}" class="btn btn-secondary btn-sm">Se déconnecter</a>
                    </div>
                </div>
            {% endif %}

            <form method="post" class="login-form">
                <div class="form-group">
                    <label for="inputEmail" class="form-label">Adresse Email</label>
                    <input 
                        type="email" 
                        value="{{ last_username }}" 
                        name="email" 
                        id="inputEmail" 
                        class="form-control" 
                        placeholder="votre@email.com"
                        autocomplete="email" 
                        required 
                        autofocus>
                    <small class="form-text">Nous ne partagerons jamais votre email</small>
                </div>

                <div class="form-group">
                    <label for="inputPassword" class="form-label">Mot de passe</label>
                    <input 
                        type="password" 
                        name="password" 
                        id="inputPassword" 
                        class="form-control" 
                        placeholder="••••••••"
                        autocomplete="current-password" 
                        required>
                </div>

                <div class="form-check">
                    <input 
                        type="checkbox" 
                        name="_remember_me" 
                        id="rememberMe" 
                        class="form-check-input">
                    <label class="form-check-label" for="rememberMe">
                        Se souvenir de moi
                    </label>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-primary btn-lg w-100" type="submit">
                    Se connecter
                </button>
            </form>

            <div class="login-footer">
                <p>Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
