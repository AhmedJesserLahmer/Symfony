    </div>
    <div class="feature">
        <img class="featureIcon" src="{{ asset('images/return.png') }}" alt="">
        <span class="featureTitle">30 DAYS RETURN</span>
        <span class="featureDesc">No question return and easy refund in 14 days.</span>
    </div>
    <div class="feature">
        <img class="featureIcon" src="{{ asset('images/gift.png') }}" alt="">
        <span class="featureTitle">GIFT CARDS</span>
        <span class="featureDesc">Buy gift cards and use coupon codes easily.</span>
    </div>
    <div class="feature">
        <img class="featureIcon" src="{{ asset('images/contact.png') }}" alt="">
        <span class="featureTitle">CONTACT US!</span>
        <span class="featureDesc">Keep in touch via email and support system.</span>
    </div>
</div>

<section class="catalog" id="catalog">
    <div class="catalogHeader">
        <h2 class="catalogTitle">Shop All</h2>
        <form method="get" class="catalogFilter">
            <div class="catalogFilterGroup">
                <label class="catalogLabel" for="category">Sneaker type</label>
                <select id="category" name="category" class="catalogSelect" onchange="this.form.submit()">
                    <option value="" {% if not selectedCategory %}selected{% endif %}>All types</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}" {% if selectedCategory and selectedCategory.id == category.id %}selected{% endif %}>
                            {{ category.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="catalogFilterGroup">
                <label class="catalogLabel" for="price">Price range</label>
                <select id="price" name="price" class="catalogSelect" onchange="this.form.submit()">
                    <option value="" {% if priceRange == '' %}selected{% endif %}>All prices</option>
                    <option value="0-120" {% if priceRange == '0-120' %}selected{% endif %}>Under $120</option>
                    <option value="120-160" {% if priceRange == '120-160' %}selected{% endif %}>$120 - $160</option>
                    <option value="160-200" {% if priceRange == '160-200' %}selected{% endif %}>$160 - $200</option>
                    <option value="200+" {% if priceRange == '200+' %}selected{% endif %}>$200+</option>
                </select>
            </div>
        </form>
    </div>
    <div class="catalogChips">
        <a
            href="{{ path('app_products', {price: priceRange}) }}"
            class="catalogChip {% if not selectedCategory %}is-active{% endif %}"
        >
            All
        </a>
        {% for category in categories %}
            <a
                href="{{ path('app_products', {category: category.id, price: priceRange}) }}"
                class="catalogChip {% if selectedCategory and selectedCategory.id == category.id %}is-active{% endif %}"
            >
                {{ category.name }}
            </a>
        {% endfor %}
    </div>

    <div class="catalogGrid">
        {% for product in products %}
            <article class="productCard">
                {% set imagePath = product.imageUrl ? product.imageUrl|trim('/') : null %}
                <a class="productMedia" href="{{ path('app_product_show', {id: product.id}) }}">
                    {% if imagePath %}
                        <img src="{{ asset(imagePath) }}" alt="{{ product.name }}">
                    {% else %}
                        <span class="catalogEmpty">No image</span>
                    {% endif %}
                </a>
                <div class="productInfo">
                    <h3 class="productName">{{ product.name }}</h3>
                    {% if product.category %}
                        <span class="productCategory">{{ product.category.name }}</span>
                    {% endif %}
                    <p class="productCopy">{{ product.description|slice(0, 90) }}...</p>
                    <div class="productMeta">
                        <span class="productCardPrice">${{ product.price }}</span>
                    </div>
                    <div class="productActions">
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="buttonOutline">View</a>
                        <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cart_add' ~ product.id) }}">
                            <button type="submit" class="buttonPrimary">Add to cart</button>
                        </form>
                    </div>
                </div>
            </article>
        {% else %}
            <p class="catalogEmpty">No products found.</p>
        {% endfor %}
    </div>
</section>

<div class="product" id="product">
    <img src="{{ asset('images/air.png') }}" alt="Air Force" class="productImg">
    <div class="productDetails">
        <h1 class="productTitle">AIR FORCE</h1>
        <h2 class="productPrice">$199</h2>
        <p class="productDesc">Classic basketball silhouette reimagined for modern streets.</p>
        <div class="colors">
            <div class="color"></div>
            <div class="color"></div>
        </div>
        <div class="sizes">
            <div class="size">42</div>
            <div class="size">43</div>
            <div class="size">44</div>
        </div>
        {% if sliderProducts[0] is defined %}
            <form
                method="post"
                action="{{ path('app_cart_add', {id: sliderProducts[0].id}) }}"
                class="productBuyForm"
                data-action-template="{{ path('app_cart_add', {id: 0}) }}"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('cart_add' ~ sliderProducts[0].id) }}">
                <button
                    class="productButton js-add-to-cart"
                    type="submit"
                    data-product-id="{{ sliderProducts[0].id }}"
                    data-cart-token="{{ csrf_token('cart_add' ~ sliderProducts[0].id) }}"
                >
                    BUY NOW!
                </button>
            </form>
        {% else %}
            <button class="productButton" type="button" disabled>BUY NOW!</button>
        {% endif %}
    </div>
</div>

