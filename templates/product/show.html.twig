{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ product.name }}</h1>
{% if product.imageUrl %}
    <img src="{{ product.imageUrl }}" style="max-width: 400px;">
{% endif %}
<p>{{ product.description }}</p>
<p><strong>Price:</strong> ${{ product.price }}</p>
<p><strong>In stock:</strong> {{ product.stock }}</p>
<a href="{{ path('app_products') }}">← Back to products</a>
{% endblock %}