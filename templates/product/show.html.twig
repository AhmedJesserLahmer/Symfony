{% extends 'base.html.twig' %}

{% block body %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            {% if product.imageUrl %}
                <img src="{{ asset(product.imageUrl) }}" alt="{{ product.name }}">
            {% endif %}
        </div>
        <div class="col-md-6">
            <h1>{{ product.name }}</h1>
            <p class="text-muted">{{ product.description }}</p>
            <h3 class="text-success">${{ product.price }}</h3>
            <p>
                {% if product.stock > 0 %}
                    <span class="badge bg-success">In Stock ({{ product.stock }} left)</span>
                {% else %}
                    <span class="badge bg-danger">Out of Stock</span>
                {% endif %}
            </p>
            <a href="{{ path('app_products') }}" class="btn btn-outline-secondary mt-3">← Back to products</a>
        </div>
    </div>
</div>
{% endblock %}