{% extends 'base.html.twig' %}

{% block body %}
<nav id="nav">
    <div class="navTop">
        <div class="navItem">
            <a href="{{ path('app_products') }}">
                <img src="{{ asset('images/sneakers.png') }}" alt="Sneakers logo">
            </a>
        </div>
        <div class="navItem">
            <div class="search">
                <input type="text" placeholder="Search..." class="searchInput" aria-label="Search">
                <img src="{{ asset('images/search.png') }}" width="20" height="20" alt="" class="searchIcon">
            </div>
        </div>
        <div class="navItem">
            <span class="limitedOffer">Limited Offer!</span>
        </div>
        <div class="navItem navCart">
            <a href="{{ path('app_cart_index') }}" class="buttonOutline">Cart</a>
        </div>
        <div class="navItem navAuth">
            {% if app.user %}
                <a href="{{ path('app_account') }}" class="buttonOutline">Account</a>
                <a href="{{ path('app_logout') }}" class="buttonPrimary">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="buttonOutline">Login</a>
            {% endif %}
        </div>
    </div>
    <div class="navBottom">
        <h3 class="menuItem">AIR FORCE</h3>
        <h3 class="menuItem">JORDAN</h3>
        <h3 class="menuItem">BLAZER</h3>
        <h3 class="menuItem">CRATER</h3>
        <h3 class="menuItem">HIPPIE</h3>
    </div>
</nav>

<div class="productPage">
    <div class="productPageMedia">
        {% set imagePath = product.imageUrl ? product.imageUrl|trim('/') : null %}
        {% if imagePath %}
            <img src="{{ asset(imagePath) }}" alt="{{ product.name }}">
        {% endif %}
    </div>
    <div class="productPageDetails">
        <a href="{{ path('app_products') }}" class="productPageBack">Back to products</a>
        <h1 class="productPageTitle">{{ product.name }}</h1>
        {% if product.category %}
            <div class="productPageCategory">Category: {{ product.category.name }}</div>
        {% endif %}
        <p class="productPageDesc">{{ product.description }}</p>
        <div class="productPagePrice">{{ product.price }} DT</div>
        <div class="productPageStock">
            {% if product.stock > 0 %}
                In stock ({{ product.stock }} left)
            {% else %}
                Out of stock
            {% endif %}
        </div>
        <div class="productPageActions">
            <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_add' ~ product.id) }}">
                <input type="hidden" name="return_to" value="{{ app.request.uri }}">
                <button type="submit" class="buttonPrimary">Add to cart</button>
            </form>
            <a href="{{ path('app_cart_index') }}" class="buttonOutline">View cart</a>
        </div>
    </div>
</div>

{% include '_footer.html.twig' %}
{% endblock %}
