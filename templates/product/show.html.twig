{% extends 'base.html.twig' %}

{% block body %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="{{ path('app_products') }}" class="btn btn-outline-secondary">Back to products</a>
        <a href="{{ path('app_cart_index') }}" class="btn btn-outline-secondary">Cart</a>
    </div>
    <div class="row">
        <div class="col-md-6">
            {% if product.imageUrl %}
                <img src="{{ asset(product.imageUrl) }}" alt="{{ product.name }}">
            {% endif %}
        </div>
        <div class="col-md-6">
            <h1>{{ product.name }}</h1>
            {% if product.category %}
                <p class="text-muted mb-1">Category: {{ product.category.name }}</p>
            {% endif %}
            <p class="text-muted">{{ product.description }}</p>
            <h3 class="text-success">${{ product.price }}</h3>
            <p>
                {% if product.stock > 0 %}
                    <span class="badge bg-success">In Stock ({{ product.stock }} left)</span>
                {% else %}
                    <span class="badge bg-danger">Out of Stock</span>
                {% endif %}
            </p>
            <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}" class="mt-3">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_add' ~ product.id) }}">
                <button type="submit" class="btn btn-success">Add to cart</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}